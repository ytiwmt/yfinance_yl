import yfinance as yf
import pandas as pd
import requests
import json

DISCORD_WEBHOOK_URL = "あなたのDiscord_Webhook_URL"

def get_sp500_tickers():
    """S&P500銘柄のリストをWikipediaから自動取得"""
    url = 'https://en.wikipedia.org/wiki/List_of_S%26P_500_companies'
    table = pd.read_html(url)
    df = table[0]
    return df['Symbol'].tolist()

def analyze_market():
    # 1. 母集団（S&P500）の取得
    all_tickers = get_sp500_tickers()
    found_opportunities = []

    print(f"Scanning {len(all_tickers)} stocks...")

    # 2. 各銘柄をスキャン（※数が多いので実際はマルチスレッド化や重要銘柄への絞り込みが理想）
    for symbol in all_tickers:
        try:
            # 取得エラー回避のため . などのシンボルを置換
            symbol = symbol.replace('.', '-')
            stock = yf.Ticker(symbol)
            info = stock.info
            
            # 基本指標
            cur_yield = info.get('dividendYield', 0) * 100
            payout = info.get('payoutRatio', 0) * 100
            
            # 利回りが低い、または配当性向が異常なものはスルー（計算コスト削減）
            if cur_yield < 3.0 or payout > 100 or payout == 0:
                continue

            # 過去平均との比較ロジック
            hist = stock.history(period="2y") # 5年だと重いので2年に短縮
            avg_price = hist['Close'].mean()
            avg_yield = (info.get('trailingAnnualDividendRate', 0) / avg_price) * 100 if avg_price > 0 else 0
            
            # バグ検知：利回りが過去平均より1.2倍以上高い
            if cur_yield > (avg_yield * 1.2):
                found_opportunities.append({
                    "Symbol": symbol,
                    "Yield": cur_yield,
                    "AvgYield": avg_yield,
                    "Payout": payout
                })

        except:
            continue

    # 3. 利回り順にソートして上位を通知
    top_deals = sorted(found_opportunities, key=lambda x: x['Yield'], reverse=True)[:10]
    
    if top_deals:
        msg = "【米国株・流動的バグ検知レポート】\n"
        for d in top_deals:
            msg += f"✅ **{d['Symbol']}**: 利回り{d['Yield']:.2f}% (平均{d['AvgYield']:.2f}%) / 配当性向{d['Payout']:.1f}%\n"
        send_discord_message(msg)
    else:
        send_discord_message("本日、条件に合致するバグ銘柄は見つかりませんでした。")

def send_discord_message(content):
    requests.post(DISCORD_WEBHOOK_URL, data=json.dumps({"content": content}), headers={"Content-Type": "application/json"})

if __name__ == "__main__":
    analyze_market()
